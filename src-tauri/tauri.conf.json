{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "editor-lite",
  "version": "0.1.2",
  "identifier": "kareemsab278.editor-lite",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "editor-lite",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "msi"],
    "icon": ["icons/icon.ico"]
  },
  "plugins": {
    "fs": {
      "scope": ["$HOME/**"]
    }
  }
}
